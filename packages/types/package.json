{
  "name": "@talos/types",
  "version": "0.0.4",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "echo \"No linting configured\"",
    "typecheck": "tsc --noEmit",
    "test": "echo \"No tests configured\"",
    "clean": "rm -rf dist"
  },
  "tsup": {
    "entry": [
      "src/index.ts"
    ],
    "format": [
      "esm"
    ],
    "dts": true,
    "clean": true,
    "treeshake": true,
    "splitting": false,
    "sourcemap": true,
    "outDir": "dist"
  },
  "devDependencies": {
    "typescript": "5.7.2"
  }
}
